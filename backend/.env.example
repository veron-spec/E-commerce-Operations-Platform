# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce_ops

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Encryption
ENCRYPTION_KEY=change-me-to-a-random-32-byte-key

# App
APP_NAME=E-Commerce Operations Platform
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret

# Taobao OAuth (must exactly match redirect_uri registered in Taobao dev console)
TAOBAO_REDIRECT_URI=http://localhost:8100/api/v1/auth/taobao/callback
